# Copy this to .env for local development and add these in Vercel → Settings → Environment Variables

# Supabase (get from supabase.com → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Google Sheets (the ID from the sheet URL: /d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Google Service Account — paste the ENTIRE contents of the downloaded JSON key file
# (all on one line, or as a multiline env var in Vercel)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
